# Anthropic API (leave blank for fully local Ollama-only mode)
ANTHROPIC_API_KEY=sk-ant-xxxxx
MIXAGENT_MODEL=claude-sonnet-4-20250514

# OpenAI API (optional — used as fallback if Anthropic is set, or as primary if not)
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o

# Ollama host/model are now configured in the desktop UI (Config tab → Local Model)
# or directly in config/show.json (ollama_host, ollama_model, ollama_primary)

MIXAGENT_LOG_LEVEL=info

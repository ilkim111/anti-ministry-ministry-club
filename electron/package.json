{
  "name": "mixagent-desktop",
  "version": "1.0.0",
  "description": "MixAgent Desktop — AI-powered live sound engineering with config management, approval workflow, and chat interface",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-backend": "cd .. && ./scripts/build.sh",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "build-all": "npm run build-backend && npm run dist",
    "build-all:mac": "npm run build-backend && npm run dist:mac",
    "build-all:win": "npm run build-backend && npm run dist:win",
    "build-all:linux": "npm run build-backend && npm run dist:linux"
  },
  "build": {
    "appId": "com.mixagent.desktop",
    "productName": "MixAgent",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "../build/mixagent",
        "to": "backend/mixagent",
        "filter": ["**/*"]
      },
      {
        "from": "../config",
        "to": "config",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "icon": "assets/icons",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Audio",
      "desktop": {
        "Name": "MixAgent",
        "Comment": "AI-powered live sound engineering",
        "Categories": "Audio;Music;Mixer"
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "OWNER",
        "repo": "anti-ministry-ministry-club",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
